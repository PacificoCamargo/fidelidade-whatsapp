{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "dockerfile": "./Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "node src/index.js",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 60000,
    "healthchecks": {
      "liveness": {
        "path": "/health",
        "interval": 30,
        "timeout": 10
      }
    }
  },
  "variables": {
    "NODE_ENV": "production",
    "PORT": "3000"
  }
}
